filetype on
filetype plugin indent on

syntax enable
syntax sync fromstart

set nocompatible
set encoding=utf-8
set smartindent
set tabstop=2
set expandtab
set shiftwidth=2
set softtabstop=2
set ruler
set showmatch
set mat=5
set incsearch
set lbr
set autoread
set mouse=a
set history=50
set laststatus=2
set showmode
set showcmd
set backspace=indent,eol,start
set noerrorbells
